# publish-public-mirror.yml — TEMPLATE, NOT ACTIVE.
#
# To activate:
#   1. Generate a deploy key for elfege/MOBIUS.SMART_HOME (the PUBLIC repo) with
#      write access. Save the private key as repo secret PUBLIC_DEPLOY_KEY
#      in elfege/MOBIUS.SMART_HOME-dev (this repo).
#   2. Rename this file to publish-public-mirror.yml.
#
# It then mirrors what scripts/publish_public_mirror.sh does locally:
# clone HEAD of main, run git filter-repo to strip private content + redact
# LAN IPs, then push the cleansed history to the public repo.
#
# IMPORTANT: this CI form uses --force (rewrite-mode equivalent). For routine
# fast-forward-only publishing, run scripts/publish_public_mirror.sh manually
# from a dev machine instead. CI is for the case where deploy automation is
# preferred over manual dev-machine invocation.
#
# Fires on:
#   - any push to main (so the public repo tracks main)
#   - any push of a vX.Y.Z tag (so tags appear on the public side too)
name: Publish public mirror

on:
  push:
    branches: [main]
    tags: ['v*.*.*']

permissions:
  contents: read

concurrency:
  group: publish-public-mirror
  cancel-in-progress: false

jobs:
  publish:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout (full history + tags)
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          fetch-tags: true

      - name: Install git-filter-repo
        run: |
          sudo apt-get update -qq
          sudo apt-get install -y git-filter-repo

      - name: Configure git identity
        run: |
          git config user.name  "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"

      - name: Set up SSH deploy key for public repo
        env:
          PUBLIC_DEPLOY_KEY: ${{ secrets.PUBLIC_DEPLOY_KEY }}
        run: |
          mkdir -p ~/.ssh
          echo "$PUBLIC_DEPLOY_KEY" > ~/.ssh/id_ed25519
          chmod 600 ~/.ssh/id_ed25519
          ssh-keyscan github.com >> ~/.ssh/known_hosts

      - name: Filter + force-push to public
        run: |
          # Replicates scripts/publish_public_mirror.sh in CI form.
          # Keep this strip set in lockstep with scripts/publish_public_mirror.sh
          # — if you add a strip rule there, mirror it here.
          RT="$(mktemp)"
          printf 'regex:192\\.168\\.10\\.[0-9]{1,3}==><LAN_IP>\n' > "$RT"
          git filter-repo --force --prune-empty never --replace-text "$RT" --filename-callback '
          strip_dirs = (
              b"docs/plans/",
              b"docs/history/",
              b"docs/teachings/",
              b"docs/weekly_summaries/",
              b"docs/patent/",
              b"backups/",
              b"DOCS/",
              b"nginx/certs/",
              b".hubitat/",
              b"_SYNCAPP/",
              b"postgres_data/",
          )
          strip_files = {
              b"docs/README_handoff.md",
              b"docs/README_project_history.md",
              b"docs/README_port_mappings.md",
              b"docs/README_daily_standup_pitch.md",
              b"CLAUDE.md",
              b"chat.md",
              b"claude_rules.md",
              b"app_structure.txt",
              b"claude_rules.txt",
              b"file_history.txt",
              b"tree.txt",
          }
          strip_prefixes = (b"docs/README_investigation_",)
          strip_suffixes = (b".pem", b".key", b".crt", b".p12", b".pfx", b".sqlite", b".db")
          strip_exact = {b".env", b"credentials.json"}

          if filename in strip_files: return None
          if filename in strip_exact: return None
          for d in strip_dirs:
              if filename.startswith(d): return None
          for p in strip_prefixes:
              if filename.startswith(p): return None
          for s in strip_suffixes:
              if filename.endswith(s): return None
          return filename
          '
          rm -f "$RT"

          # Leak gates — abort if anything flagged survived.
          LEAKS="$(git ls-files | grep -E '\.(pem|key|crt|p12|pfx|sqlite|db)$|^(docs/(plans|history|teachings|weekly_summaries|patent)/|backups/|DOCS/|nginx/certs/|\.hubitat/|_SYNCAPP/|postgres_data/|chat\.md$|claude_rules\.md$|CLAUDE\.md$|app_structure\.txt$|claude_rules\.txt$|file_history\.txt$|tree\.txt$|docs/README_(handoff|project_history|port_mappings|daily_standup_pitch|investigation_)|credentials\.json$|\.env$)' || true)"
          if [ -n "$LEAKS" ]; then echo "ABORT — leaks survived: $LEAKS"; exit 1; fi
          IP_LEAKS="$(git grep -lE '192\.168\.10\.[0-9]' -- . 2>/dev/null || true)"
          if [ -n "$IP_LEAKS" ]; then echo "ABORT — LAN IPs survived: $IP_LEAKS"; exit 1; fi

          git remote add public git@github.com:elfege/MOBIUS.SMART_HOME.git
          git push --force public HEAD:main
          git push --force public --tags
