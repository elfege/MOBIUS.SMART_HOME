
# Port allocation (slot 2 in global port scheme)
NGINX_HTTP_PORT=8082
NGINX_HTTPS_PORT=8445
POSTGRES_EXTERNAL_PORT=5433
POSTGREST_EXTERNAL_PORT=3002

# Samsung TV WebSocket token (obtained during first pairing handshake)
SAMSUNG_TV_TOKEN=your_token_here

# Name shown to the TV during WS pairing
SAMSUNG_TV_APP_NAME='Smart Home Controller'
