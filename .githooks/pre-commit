#!/bin/bash
# ╔══════════════════════════════════════════════════════════════════════════════════════╗
# ║  .githooks/pre-commit                                                                ║
# ║                                                                                      ║
# ║  Keeps the in-repo copies of color/logger helpers in sync with the developer's       ║
# ║  home copies before every commit. End-user clones have no ~/.env.colors or           ║
# ║  ~/logger.sh, so the hook is a silent no-op there — safe to ship on the public       ║
# ║  repo.                                                                               ║
# ║                                                                                      ║
# ║      ~/.env.colors ──┐                                                               ║
# ║                      │ rsync (if newer)                                              ║
# ║      ~/logger.sh ────┴──▶ ./<repo-root>/{.env.colors,logger.sh} ──▶ git add          ║
# ╚══════════════════════════════════════════════════════════════════════════════════════╝
set -e

REPO_ROOT="$(builtin cd "$(git rev-parse --show-toplevel)" && pwd)"
CHANGED=0

for f in .env.colors logger.sh; do
	src="$HOME/$f"
	dst="$REPO_ROOT/$f"
	# Only act when the home copy exists (dev machine). Compare with cmp so we
	# don't restage when nothing actually changed.
	[ -f "$src" ] || continue
	if [ ! -f "$dst" ] || ! cmp -s "$src" "$dst"; then
		rsync -auv "$src" "$dst" >/dev/null
		git add "$dst"
		CHANGED=1
	fi
done

[ "$CHANGED" -eq 1 ] && echo "pre-commit: refreshed in-repo .env.colors / logger.sh from home"
exit 0
