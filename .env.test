# =============================================================================
# .env.test — the ETT TEST STACK environment (canonical ETT.1-7; NVR v6.7.x ref)
# =============================================================================
# Used ONLY by:  docker compose -p smarthome_test --env-file .env.test ...
# (start.sh --test / stop.sh --test / test.sh / status.sh --test)
#
# ISOLATION — same compose file as prod, different everything at runtime:
#   * project name `smarthome_test`  -> its OWN named volumes (fresh empty DB)
#   * CONTAINER_PREFIX               -> no container-name collisions with prod
#   * port offsets (+1000)           -> no port collisions with prod
#
# SAFETY — the test stack must NEVER act on the real house. Layered guards:
#   1. Fresh empty database  -> zero app_instances -> no automations exist.
#   2. DUMMY hub tokens      -> any accidental Hubitat call fails auth (401).
#   3. EVENTSOCKET_ENABLED=false -> no live hub event intake.
#   4. matter-server / autoheal / webhook-dispatcher are NOT started
#      (start.sh --test brings up only: smart-home postgres postgrest nginx).
#   5. No MATTER_CODE_ENC_KEY -> vault inert (fail-closed) in tests.
#
# NO AWS SECRETS REQUIRED: this file is self-sufficient, values are dummies.
# It is COMMITTED on purpose — nothing in here is secret.
# =============================================================================

CONTAINER_PREFIX=smarthome_test_

# 🔴 THE TWO LINES THAT KEEP THE TEST STACK OFF THE LIVE HOUSE.
#
# docker-compose.yml declares postgres_data and smarthome-net as EXTERNAL with
# FIXED names. External + fixed-name means NOT project-scoped: `docker compose
# -p smarthome_test` would otherwise mount the LIVE DATABASE VOLUME and join the
# LIVE NETWORK — which is exactly what happened on the first --test bring-up
# (2026-07-13). A second postmaster ran on the operator's live data directory.
# It survived, but only by luck (the dummy password below got it rejected).
#
# These overrides give the test stack its own volume + its own network, so it
# gets the FRESH EMPTY DATABASE it was always meant to have and literally cannot
# resolve, reach, or mount anything belonging to the live stack.
# start.sh --test creates both if they do not exist (external volumes/networks
# are never auto-created by compose).
POSTGRES_VOLUME_NAME=smarthome_test_postgres_data
NETWORK_NAME=smarthome_test_net

# --- ports: prod +1000 ------------------------------------------------------
APP_EXTERNAL_PORT=6001
POSTGRES_EXTERNAL_PORT=6433
POSTGREST_EXTERNAL_PORT=4002
NGINX_HTTP_PORT=9082
NGINX_HTTPS_PORT=9445
WEBHOOK_PORT=6050
MATTER_PORT=6580

# --- database (fresh volume; initdb runs psql/02-apply-migrations.sh) --------
POSTGRES_DB=smarthome
POSTGRES_USER=smarthome_api
POSTGRES_PASSWORD=test_only_not_a_secret

# --- app ----------------------------------------------------------------------
APP_API_TOKEN=test-api-token-not-real
SERVER_IP=127.0.0.1
EVENTSOCKET_ENABLED=false

# --- Hubitat: REAL IPs ARE NOT LISTED; tokens are DUMMIES ---------------------
# TEST-net IP (RFC 5737, unroutable) so even a code path that ignores the token
# cannot reach a real hub.
HUBITAT_HUB_IP_MAIN=192.0.2.1
HUBITAT_API_NUMBER_MAIN=0
HUBITAT_API_TOKEN_MAIN=dummy-test-token
HUBITAT_HUB_IP_OTHER_HUB_1=
HUBITAT_API_NUMBER_OTHER_HUB_1=
HUBITAT_API_TOKEN_OTHER_HUB_1=
HUBITAT_HUB_IP_OTHER_HUB_2=
HUBITAT_API_NUMBER_OTHER_HUB_2=
HUBITAT_API_TOKEN_OTHER_HUB_2=
HUBITAT_HUB_IP_OTHER_HUB_3=
HUBITAT_API_NUMBER_OTHER_HUB_3=
HUBITAT_API_TOKEN_OTHER_HUB_3=

# --- Samsung TV: unroutable dummy --------------------------------------------
SAMSUNG_TV_IP=192.0.2.2
SAMSUNG_TV_MAC=000000000000
SAMSUNG_TV_NAME=test_tv
SAMSUNG_TV_TOKEN=
SAMSUNG_TV_SSL=true

# --- Matter: no controller in the test stack ---------------------------------
MATTER_CONTROLLER_IMPL=matterjs-server
MATTER_CODE_ENC_KEY=
